# Server
PORT=3000
# Used for auth cookie security (secure cookies when set to production)
NODE_ENV=development

# Auth / OpenAI
JWT_SECRET=replace-me
ADMIN_USER=admin
ADMIN_PASS=replace-me
LLM_API_KEY=

# RescueGroups API
RESCUE_GROUPS_ENDPOINT=
RESCUE_GROUPS_BEARER=

# Notes provider toggle
# true  -> AWS-backed notes repository
# false -> RescueGroups-backed notes repository (journal entry types 60460/60461)
USE_AWS_NOTES=false

# AWS (local defaults)
AWS_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
